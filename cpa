<script>
// Tab switching
function switchTab(id) {
  document.querySelectorAll('.subject-section').forEach(s => s.classList.remove('active'));
  document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
  document.getElementById('sec-' + id).classList.add('active');
  // Find and activate tab button
  document.querySelectorAll('.tab-btn').forEach(b => {
    const tabMap = {
      'overview':'总览','accounting':'会计','audit':'审计','tax':'税法',
      'law':'经济法','fm':'财务成本管理','strategy':'公司战略','comprehensive':'综合阶段'
    };
    if (b.textContent === tabMap[id]) b.classList.add('active');
  });
  // Scroll to top of content
  document.getElementById('header').scrollIntoView({behavior:'smooth'});
}

// Expand/collapse
function toggleItem(el) {
  el.classList.toggle('expanded');
}

// Scroll to top button
window.addEventListener('scroll', () => {
  const btn = document.getElementById('scrollTop');
  if (window.scrollY > 400) btn.classList.add('show');
  else btn.classList.remove('show');
});

// Search
function doSearch(query) {
  // Show all sections when searching
  const allSections = document.querySelectorAll('.subject-section');
  const allItems = document.querySelectorAll('.knowledge-item');
  const allGroups = document.querySelectorAll('.knowledge-group');

  if (!query.trim()) {
    // Restore normal view
    allSections.forEach(s => s.style.display = '');
    allSections.forEach(s => s.classList.remove('active'));
    document.getElementById('sec-overview').classList.add('active');
    allItems.forEach(item => {
      item.style.display = '';
      // Remove marks
      item.querySelectorAll('mark').forEach(m => {
        m.replaceWith(document.createTextNode(m.textContent));
      });
    });
    return;
  }

  // Show all sections
  allSections.forEach(s => { s.style.display = 'block'; s.classList.add('active'); });

  const lowerQ = query.toLowerCase();
  allItems.forEach(item => {
    const text = item.textContent.toLowerCase();
    if (text.includes(lowerQ)) {
      item.style.display = '';
      item.classList.add('expanded');
      // Highlight
      const body = item.querySelector('.k-body');
      const title = body.querySelector('.k-title');
      const detail = body.querySelector('.k-detail');
      [title, detail].forEach(el => {
        if (!el) return;
        const inner = el.innerHTML;
        // Remove existing marks first
        let cleaned = inner.replace(/<mark>/g,'').replace(/<\/mark>/g,'');
        const regex = new RegExp(`(${query.replace(/[.*+?^${}()|[\]\\]/g,'\\$&')})`, 'gi');
        el.innerHTML = cleaned.replace(regex, '<mark>$1</mark>');
      });
    } else {
      item.style.display = 'none';
    }
  });

  // Hide empty groups
  allGroups.forEach(g => {
    const visible = g.querySelectorAll('.knowledge-item:not([style*="display: none"])');
    g.style.display = visible.length > 0 ? '' : 'none';
  });
}
</script>

